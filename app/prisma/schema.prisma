generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  department_officer
  field_inspector
  citizen
}

enum AssetStatus {
  active
  inactive
  under_maintenance
  decommissioned
}

enum AssetType {
  road
  streetlight
  water_pump
  toilet
  bench
  hospital_line
  other
}

enum ReportSource {
  citizen
  inspector
  sensor
}

enum AlertSeverity {
  low
  medium
  high
  critical
}

enum WorkOrderStatus {
  open
  in_progress
  completed
  cancelled
}

enum WorkOrderPriority {
  low
  medium
  high
  critical
}

model Department {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())

  assets    Asset[]
  users     User[]
  workOrders WorkOrder[]

  @@map("departments")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  phone         String?
  passwordHash  String    @map("password_hash")
  role          UserRole
  departmentId  String?   @map("department_id")
  stateCode     String?   @map("state_code")
  districtCode  String?   @map("district_code")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")

  department    Department? @relation(fields: [departmentId], references: [id])
  reports       AssetReport[]
  assignedWorkOrders WorkOrder[] @relation("AssignedTo")

  @@map("users")
}

model Asset {
  id              String      @id @default(uuid())
  assetCode       String      @unique @map("asset_code")
  name            String
  assetType       AssetType   @map("asset_type")
  departmentId    String      @map("department_id")
  stateCode       String      @map("state_code")
  districtCode    String      @map("district_code")
  address         String
  latitude        Float
  longitude       Float
  installDate     DateTime?   @map("install_date")
  currentScore    Float?      @map("current_score")
  lastReportedAt  DateTime?   @map("last_reported_at")
  status          AssetStatus @default(active)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  department      Department @relation(fields: [departmentId], references: [id])
  reports         AssetReport[]
  workOrders      WorkOrder[]
  alerts          Alert[]

  @@map("assets")
}

model AssetReport {
  id              String       @id @default(uuid())
  assetId         String       @map("asset_id")
  reporterId      String       @map("reporter_id")
  score           Float
  previousScore   Float?       @map("previous_score")
  scoreDelta      Float?       @map("score_delta")
  notes           String?
  photoUrl        String?      @map("photo_url")
  sourceType      ReportSource @map("source_type")
  latitude        Float?
  longitude       Float?
  reportedAt      DateTime     @default(now()) @map("reported_at")
  createdAt       DateTime     @default(now()) @map("created_at")

  asset           Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  reporter        User         @relation(fields: [reporterId], references: [id])
  alerts          Alert[]
  workOrders      WorkOrder[]

  @@map("asset_reports")
}

model Alert {
  id              String        @id @default(uuid())
  assetId         String        @map("asset_id")
  reportId        String        @map("report_id")
  alertType       String        @map("alert_type")
  severity        AlertSeverity
  message         String
  isAcknowledged  Boolean       @default(false) @map("is_acknowledged")
  createdAt       DateTime      @default(now()) @map("created_at")

  asset           Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  report          AssetReport   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("alerts")
}

model WorkOrder {
  id              String            @id @default(uuid())
  assetId         String            @map("asset_id")
  triggerReportId String            @map("trigger_report_id")
  priority        WorkOrderPriority
  departmentId    String            @map("department_id")
  status          WorkOrderStatus   @default(open)
  reason          String
  assignedTo      String?           @map("assigned_to")
  createdAt       DateTime          @default(now()) @map("created_at")
  resolvedAt      DateTime?         @map("resolved_at")

  asset           Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  triggerReport   AssetReport       @relation(fields: [triggerReportId], references: [id], onDelete: Cascade)
  department      Department        @relation(fields: [departmentId], references: [id])
  assignedUser    User?             @relation("AssignedTo", fields: [assignedTo], references: [id])

  @@map("work_orders")
}

model DistrictMetricsDaily {
  id                      String   @id @default(uuid())
  stateCode               String   @map("state_code")
  districtCode            String   @map("district_code")
  metricDate              DateTime @map("metric_date")
  assetCount              Int      @map("asset_count")
  healthyCount            Int      @map("healthy_count")
  minorDegradationCount   Int      @map("minor_degradation_count")
  moderateDegradationCount Int     @map("moderate_degradation_count")
  severeDegradationCount  Int      @map("severe_degradation_count")
  deadCount               Int      @map("dead_count")
  halfStepIndex           Float    @map("half_step_index")

  @@unique([stateCode, districtCode, metricDate])
  @@map("district_metrics_daily")
}
